# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/kozmo

# Secret used to sign JWT access tokens
SECRET=replace-with-a-long-random-string

# Stripe API secret key (products live in Stripe)
STRIPE_SECRET=sk_test_xxx

# Stripe webhook signing secret (for /api/checkout/webhook)
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Frontend origin — used for CORS and Stripe redirect URLs
CLIENT_URL=http://localhost:5173
# Optional alternate/fallback client origin
CLIENT_URL_ALT=

# Optional — defaults to 3001
PORT=3001

# Comma-separated usernames always treated as admin (no DB flag needed)
ADMIN_USERNAMES=

# Cloudinary — hosts product images uploaded from the admin page
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=xxx
CLOUDINARY_API_SECRET=xxx
